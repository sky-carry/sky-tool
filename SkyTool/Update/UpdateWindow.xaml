<Window x:Class="SkyTool.Update.UpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="检查更新" Width="460" Height="430"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize" ShowInTaskbar="True" Topmost="True"
        Background="#1E1E2A" Foreground="#E8E8F2"
        FontFamily="Microsoft YaHei UI" FontSize="13">
    <Window.Resources>
        <Style x:Key="Pill" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.88"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="22,20,22,18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <TextBlock Text="&#x1F389;" FontSize="20" VerticalAlignment="Center"/>
            <TextBlock x:Name="TitleText" Text="发现新版本" FontSize="17" FontWeight="SemiBold"
                       Margin="10,0,0,0" VerticalAlignment="Center"/>
        </StackPanel>
        <TextBlock x:Name="SubText" Grid.Row="1" Margin="0,6,0,0" Foreground="#9AA0C0"/>

        <!-- 更新内容 -->
        <Border Grid.Row="2" Margin="0,14,0,0" Background="#15151F" CornerRadius="8"
                BorderBrush="#33344E" BorderThickness="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12,10">
                <TextBlock x:Name="NotesText" Foreground="#D6DAEC" TextWrapping="Wrap" LineHeight="22"/>
            </ScrollViewer>
        </Border>

        <!-- 下载进度（默认隐藏） -->
        <StackPanel x:Name="ProgressRow" Grid.Row="3" Margin="0,16,0,0" Visibility="Collapsed">
            <Grid>
                <TextBlock x:Name="StatusText" Text="正在下载…" Foreground="#9AA0C0"/>
                <TextBlock x:Name="PercentText" Text="0%" Foreground="#9AA0C0" HorizontalAlignment="Right"/>
            </Grid>
            <ProgressBar x:Name="Bar" Height="8" Margin="0,8,0,0" Minimum="0" Maximum="100"
                         Background="#262638" Foreground="#7AA2F7" BorderThickness="0"/>
        </StackPanel>

        <!-- 按钮 -->
        <StackPanel x:Name="BtnRow" Grid.Row="4" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Content="以后再说" Click="Later_Click" Style="{StaticResource Pill}" Background="#2E2E44"/>
            <Button x:Name="UpdateBtn" Content="立即更新" Click="Update_Click" Style="{StaticResource Pill}" Background="#2F6BFF"/>
        </StackPanel>
    </Grid>
</Window>
