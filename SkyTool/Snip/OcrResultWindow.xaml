<Window x:Class="SkyTool.Snip.OcrResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" Topmost="True" ResizeMode="NoResize"
        SizeToContent="WidthAndHeight" WindowStartupLocation="Manual"
        FontFamily="Microsoft YaHei UI">
    <Window.Resources>
        <!-- 关闭 × -->
        <Style x:Key="IconBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#9AA0B4"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Width" Value="26"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="13">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F0F1F6"/>
                                <Setter Property="Foreground" Value="#555B70"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- 文字按钮通用模板 -->
        <Style x:Key="PillBtn" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="18,7"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.88"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- 外层 Margin 给阴影留空间 -->
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="11"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="11"/>
        </Grid.RowDefinitions>

        <!-- 上尖角：气泡在选区下方时显示 -->
        <Path x:Name="TailUp" Grid.Row="0" Fill="White" HorizontalAlignment="Left"
              Visibility="Collapsed" Data="M0,11 L11,0 L22,11 Z"/>

        <!-- 卡片 -->
        <Border x:Name="Card" Grid.Row="1" Background="White" CornerRadius="12"
                BorderBrush="#ECEEF5" BorderThickness="1" MaxWidth="440">
            <Border.Effect>
                <DropShadowEffect BlurRadius="22" ShadowDepth="3" Opacity="0.16" Color="#22314F"/>
            </Border.Effect>
            <Grid Margin="18,12,12,14" MaxWidth="404">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 标题 -->
                <Grid Grid.Row="0" x:Name="HeaderRow">
                    <TextBlock Text="提取文字" FontSize="14" Foreground="#3A3F52"
                               VerticalAlignment="Center" HorizontalAlignment="Left"/>
                    <Button Style="{StaticResource IconBtn}" Content="&#xE711;"
                            HorizontalAlignment="Right" Margin="0,-4,-4,0" Click="Close_Click"/>
                </Grid>

                <!-- 文字（默认只读，可滚动） -->
                <Border Grid.Row="1" Margin="0,8,0,0" MaxHeight="380">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <TextBox x:Name="ResultBox" IsReadOnly="True" IsReadOnlyCaretVisible="False"
                                 Background="Transparent" BorderThickness="0" Padding="0"
                                 Foreground="#2C313F" FontSize="14"
                                 TextWrapping="Wrap" AcceptsReturn="True"
                                 CaretBrush="#2F6BFF" SelectionBrush="#B9D0FF"/>
                    </ScrollViewer>
                </Border>

                <!-- 按钮 -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                    <Button x:Name="EditBtn" Content="编辑" Click="Edit_Click"
                            Style="{StaticResource PillBtn}" Background="#EEF1FB" Foreground="#2F6BFF"/>
                    <Button x:Name="CopyBtn" Content="复制" Click="Copy_Click"
                            Style="{StaticResource PillBtn}" Background="#2F6BFF"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 下尖角：气泡在选区上方时显示 -->
        <Path x:Name="TailDown" Grid.Row="2" Fill="White" HorizontalAlignment="Left"
              Visibility="Collapsed" Data="M0,0 L22,0 L11,11 Z"/>
    </Grid>
</Window>
