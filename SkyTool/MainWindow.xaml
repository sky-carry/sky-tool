<Window x:Class="SkyTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sky 工具箱" Width="430" SizeToContent="Height"
        WindowStartupLocation="CenterScreen" ResizeMode="CanMinimize"
        WindowStyle="None" Background="{StaticResource BgBrush}"
        FontFamily="Segoe UI" TextOptions.TextRenderingMode="ClearType">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="44" ResizeBorderThickness="0" GlassFrameThickness="0" CornerRadius="0"/>
    </WindowChrome.WindowChrome>
    <Window.Resources>
        <Style x:Key="Card" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="16,5"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="10"
                                Padding="{TemplateBinding Padding}" BorderThickness="1"
                                BorderBrush="Transparent">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource Surface2Brush}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource StrokeBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="KeyChip" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource AccentDimBrush}"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <StackPanel>
        <!-- 标题栏 -->
        <DockPanel Height="44">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Top"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                <Button Style="{StaticResource CaptionBtn}" Content="&#xE921;" ToolTip="最小化" Click="Min_Click"/>
                <Button Style="{StaticResource CaptionBtn}" Content="&#xE8BB;" ToolTip="收进托盘" Click="CloseToTray_Click"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="18,0,0,0" VerticalAlignment="Center">
                <TextBlock Text="🧰" FontSize="16" VerticalAlignment="Center"/>
                <TextBlock Text="Sky 工具箱" Foreground="{StaticResource TextBrush}" FontSize="15"
                           FontWeight="SemiBold" Margin="8,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
        </DockPanel>

        <Button Style="{StaticResource Card}" Click="Snip_Click">
            <DockPanel>
                <Border DockPanel.Dock="Right" Style="{StaticResource KeyChip}">
                    <TextBlock x:Name="SnipKey" Foreground="{StaticResource AccentBrush}" FontSize="12"/>
                </Border>
                <Border Width="40" Height="40" CornerRadius="10" Background="#332E86FF" Margin="0,0,12,0">
                    <TextBlock Text="✂️" FontSize="19" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="截图 / 贴图" Foreground="{StaticResource TextBrush}" FontSize="14" FontWeight="SemiBold"/>
                    <TextBlock Text="框选标注，F3 把图钉在屏幕最前" Foreground="{StaticResource SubBrush}"
                               FontSize="11.5" Margin="0,2,8,0" TextWrapping="Wrap"/>
                </StackPanel>
            </DockPanel>
        </Button>

        <Button Style="{StaticResource Card}" Click="Search_Click">
            <DockPanel>
                <Border DockPanel.Dock="Right" Style="{StaticResource KeyChip}">
                    <TextBlock x:Name="SearchKey" Foreground="{StaticResource AccentBrush}" FontSize="12"/>
                </Border>
                <Border Width="40" Height="40" CornerRadius="10" Background="#334ECB71" Margin="0,0,12,0">
                    <TextBlock Text="🔍" FontSize="19" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="文件搜索" Foreground="{StaticResource TextBrush}" FontSize="14" FontWeight="SemiBold"/>
                    <TextBlock Text="全盘文件名即时搜索，Everything 同原理" Foreground="{StaticResource SubBrush}"
                               FontSize="11.5" Margin="0,2,8,0" TextWrapping="Wrap"/>
                </StackPanel>
            </DockPanel>
        </Button>

        <Button Style="{StaticResource Card}" Click="Memo_Click">
            <DockPanel>
                <Border DockPanel.Dock="Right" Style="{StaticResource KeyChip}">
                    <TextBlock x:Name="MemoKey" Foreground="{StaticResource AccentBrush}" FontSize="12"/>
                </Border>
                <Border Width="40" Height="40" CornerRadius="10" Background="#33F5C97B" Margin="0,0,12,0">
                    <TextBlock Text="📌" FontSize="19" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="桌面备忘录" Foreground="{StaticResource TextBrush}" FontSize="14" FontWeight="SemiBold"/>
                    <TextBlock Text="钉在桌面的今日待办，定时提醒不误事" Foreground="{StaticResource SubBrush}"
                               FontSize="11.5" Margin="0,2,8,0" TextWrapping="Wrap"/>
                </StackPanel>
            </DockPanel>
        </Button>

        <TextBlock x:Name="IndexStatus" Foreground="{StaticResource FaintBrush}" FontSize="11"
                   Margin="20,12,20,0" TextWrapping="Wrap" Text="索引启动中…"/>
        <TextBlock Foreground="{StaticResource FaintBrush}" FontSize="11" Margin="20,4,20,16"
                   Text="关闭窗口不会退出，工具箱常驻系统托盘。"/>
    </StackPanel>
</Window>
