<Window x:Class="SkyTool.Memo.MemoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="桌面备忘录" Width="320" SizeToContent="Height"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" ResizeMode="NoResize" Topmost="False">
    <Window.Resources>
        <Style x:Key="FlatBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#FFB8BECF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF3A3A50"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="10" Background="#F21E1E2E" BorderBrush="#FF44475A" BorderThickness="1">
        <StackPanel>
            <!-- 标题栏 -->
            <DockPanel Margin="12,10,8,8" MouseLeftButtonDown="Header_Drag">
                <Button DockPanel.Dock="Right" x:Name="CollapseBtn" Style="{StaticResource FlatBtn}"
                        Content="▾" ToolTip="收起/展开" Click="Collapse_Click"/>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="📌" FontSize="14" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TitleText" Margin="6,0,0,0" Foreground="White"
                               FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBlock x:Name="CountText" Margin="8,0,0,0" Foreground="#FF9DA3B4"
                               FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>
            </DockPanel>

            <!-- 主体（可收起） -->
            <StackPanel x:Name="Body">
                <!-- 添加行 -->
                <Grid Margin="12,0,12,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="56"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="NewTaskBox" Grid.Column="0" Padding="6,4" FontSize="13"
                             Background="#FF2A2A3E" Foreground="White" BorderBrush="#FF44475A"
                             CaretBrush="White" KeyDown="NewTaskBox_KeyDown"
                             ToolTip="输入任务，回车添加"/>
                    <TextBox x:Name="NewTimeBox" Grid.Column="1" Padding="4" FontSize="13" Margin="6,0,0,0"
                             Background="#FF2A2A3E" Foreground="White" BorderBrush="#FF44475A"
                             CaretBrush="White" KeyDown="NewTaskBox_KeyDown"
                             ToolTip="提醒时间（可选），如 14:30"/>
                    <Button Grid.Column="2" Style="{StaticResource FlatBtn}" Content="＋" FontSize="16"
                            Margin="4,0,0,0" ToolTip="添加任务" Click="Add_Click"/>
                </Grid>

                <!-- 任务列表 -->
                <ScrollViewer MaxHeight="420" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="TaskList" Margin="8,0,8,4">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="6" Padding="6,5" Margin="2,1">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#FF2A2A3E"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <DockPanel>
                                        <CheckBox DockPanel.Dock="Left" IsChecked="{Binding Done, Mode=TwoWay}"
                                                  VerticalAlignment="Center"/>
                                        <Button DockPanel.Dock="Right" Content="✕" FontSize="11"
                                                Style="{StaticResource FlatBtn}" ToolTip="删除"
                                                Click="Delete_Click" Tag="{Binding}"/>
                                        <TextBlock DockPanel.Dock="Right" Text="{Binding RemindText}"
                                                   Foreground="#FFFFB300" FontSize="11" Margin="6,0"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Text}" Foreground="#FFE0E0E0" FontSize="13"
                                                   Margin="6,0,0,0" TextWrapping="Wrap" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Done}" Value="True">
                                                            <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                            <Setter Property="Foreground" Value="#FF6B7089"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <TextBlock x:Name="EmptyHint" Text="今天还没有任务，写一条吧 ☕"
                           Foreground="#FF6B7089" FontSize="12" Margin="14,2,12,6"
                           Visibility="Collapsed"/>

                <!-- 底部操作 -->
                <DockPanel Margin="10,2,10,10">
                    <Button DockPanel.Dock="Right" Style="{StaticResource FlatBtn}" Content="清除已完成"
                            FontSize="11" Click="ClearDone_Click"/>
                    <TextBlock x:Name="DoneStat" Foreground="#FF6B7089" FontSize="11" VerticalAlignment="Center" Margin="4,0"/>
                </DockPanel>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
