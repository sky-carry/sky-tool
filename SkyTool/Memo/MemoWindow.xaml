<Window x:Class="SkyTool.Memo.MemoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="桌面备忘录" Width="344" SizeToContent="Height"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" ResizeMode="NoResize" Topmost="False" FontFamily="Segoe UI">

    <Grid Margin="10">
        <Border CornerRadius="14" Background="#F5212132" BorderBrush="{StaticResource StrokeBrush}"
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="16" ShadowDepth="3" Opacity="0.45" Color="Black"/>
            </Border.Effect>
            <StackPanel>
                <!-- 标题栏（可拖动） -->
                <DockPanel Margin="16,12,10,6" MouseLeftButtonDown="Header_Drag" Background="Transparent">
                    <Button DockPanel.Dock="Right" x:Name="CollapseBtn" Style="{StaticResource IconBtn}"
                            Content="&#xE70E;" FontSize="11" ToolTip="收起/展开" Click="Collapse_Click"/>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📌" FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Text="今日待办" Margin="7,0,0,0" Foreground="{StaticResource TextBrush}"
                                       FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock x:Name="CountText" Margin="8,1,0,0" Foreground="{StaticResource FaintBrush}"
                                       FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock x:Name="DateText" Foreground="{StaticResource SubBrush}" FontSize="11"
                                   Margin="1,3,0,0"/>
                    </StackPanel>
                </DockPanel>

                <!-- 完成进度条 -->
                <Grid x:Name="ProgressTrack" Height="4" Margin="17,4,17,2">
                    <Border Background="{StaticResource SurfaceBrush}" CornerRadius="2"/>
                    <Border x:Name="ProgressFill" Background="{StaticResource GreenBrush}" CornerRadius="2"
                            HorizontalAlignment="Left" Width="0"/>
                </Grid>

                <!-- 主体（可收起） -->
                <StackPanel x:Name="Body" Margin="0,6,0,0">
                    <!-- 添加行 -->
                    <Grid Margin="14,0,14,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="54"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="NewTaskBox" Grid.Column="0" Style="{StaticResource ModernTextBox}"
                                 Tag="添加任务，回车确认" KeyDown="NewTaskBox_KeyDown"/>
                        <TextBox x:Name="NewTimeBox" Grid.Column="1" Style="{StaticResource ModernTextBox}"
                                 Tag="9:30" Margin="6,0,0,0" KeyDown="NewTaskBox_KeyDown"
                                 ToolTip="提醒时间（可选），24 小时制"/>
                        <Button Grid.Column="2" Style="{StaticResource IconBtn}" Content="&#xE710;"
                                Margin="4,0,0,0" ToolTip="添加任务" Click="Add_Click"
                                Foreground="{StaticResource AccentBrush}"/>
                    </Grid>

                    <!-- 任务列表 -->
                    <ScrollViewer MaxHeight="430" VerticalScrollBarVisibility="Auto" Margin="8,0">
                        <ItemsControl x:Name="TaskList" Margin="4,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border x:Name="RowBd" CornerRadius="8" Padding="9,7" Margin="0,1.5"
                                            Background="Transparent">
                                        <DockPanel>
                                            <CheckBox DockPanel.Dock="Left" Style="{StaticResource TaskCheck}"
                                                      IsChecked="{Binding Done, Mode=TwoWay}"
                                                      VerticalAlignment="Center"/>
                                            <StackPanel x:Name="RowActions" DockPanel.Dock="Right"
                                                        Orientation="Horizontal" Opacity="0" VerticalAlignment="Center">
                                                <Button Style="{StaticResource IconBtn}" Content="&#xE823;" FontSize="12"
                                                        Padding="5,4" ToolTip="设置提醒时间"
                                                        Click="Clock_Click" Tag="{Binding}"/>
                                                <Button Style="{StaticResource IconBtn}" Content="&#xE711;" FontSize="11"
                                                        Padding="5,4" ToolTip="删除"
                                                        Click="Delete_Click" Tag="{Binding}"/>
                                            </StackPanel>
                                            <StackPanel Margin="10,0,6,0" VerticalAlignment="Center">
                                                <TextBlock x:Name="TaskText" Text="{Binding Text}"
                                                           Foreground="{StaticResource TextBrush}" FontSize="13"
                                                           TextWrapping="Wrap"/>
                                                <Border HorizontalAlignment="Left" Background="#2EF5C97B"
                                                        CornerRadius="6" Padding="6,1.5" Margin="0,3,0,0"
                                                        Visibility="{Binding HasReminder, Converter={StaticResource BoolVis}}">
                                                    <TextBlock Text="{Binding RemindText}"
                                                               Foreground="{StaticResource AmberBrush}" FontSize="10.5"/>
                                                </Border>
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <Trigger SourceName="RowBd" Property="IsMouseOver" Value="True">
                                            <Setter TargetName="RowBd" Property="Background" Value="#FF2C2C42"/>
                                            <Setter TargetName="RowActions" Property="Opacity" Value="1"/>
                                        </Trigger>
                                        <DataTrigger Binding="{Binding Done}" Value="True">
                                            <Setter TargetName="TaskText" Property="TextDecorations" Value="Strikethrough"/>
                                            <Setter TargetName="TaskText" Property="Foreground" Value="{StaticResource FaintBrush}"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <TextBlock x:Name="EmptyHint" Text="今天还没有任务，写一条吧 ☕"
                               Foreground="{StaticResource FaintBrush}" FontSize="12" Margin="18,4,16,6"
                               Visibility="Collapsed"/>

                    <!-- 底部操作 -->
                    <DockPanel Margin="16,4,12,12">
                        <Button DockPanel.Dock="Right" Style="{StaticResource IconBtn}" FontFamily="Segoe UI"
                                Content="清除已完成" FontSize="11" Click="ClearDone_Click"/>
                        <TextBlock x:Name="DoneStat" Foreground="{StaticResource FaintBrush}" FontSize="11"
                                   VerticalAlignment="Center"/>
                    </DockPanel>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- 每任务的时间编辑弹层 -->
        <Popup x:Name="TimePopup" StaysOpen="False" AllowsTransparency="True"
               Placement="Bottom" PopupAnimation="Fade">
            <Border Background="{StaticResource SurfaceBrush}" CornerRadius="10" Padding="10"
                    BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1" Margin="8">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.5" Color="Black"/>
                </Border.Effect>
                <StackPanel Orientation="Horizontal">
                    <TextBox x:Name="TimeEditBox" Width="62" Style="{StaticResource ModernTextBox}"
                             Tag="14:00" KeyDown="TimeEditBox_KeyDown"/>
                    <Button Style="{StaticResource PillBtn}" Background="{StaticResource GreenBrush}"
                            Foreground="#16291B" Content="确定" FontSize="12" Padding="12,5"
                            Margin="8,0,0,0" Click="TimeApply_Click"/>
                    <Button Style="{StaticResource PillBtn}" Content="清除" FontSize="12" Padding="12,5"
                            Margin="6,0,0,0" Click="TimeClear_Click"/>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</Window>
