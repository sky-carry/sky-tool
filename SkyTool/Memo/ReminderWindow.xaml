<Window x:Class="SkyTool.Memo.ReminderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="340" SizeToContent="Height"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" ResizeMode="NoResize" ShowActivated="True">
    <Border CornerRadius="10" Background="#F8252538" BorderBrush="#FFFFB300" BorderThickness="1.5"
            Padding="16,14">
        <StackPanel>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="⏰" FontSize="22" VerticalAlignment="Center"/>
                <StackPanel Margin="10,0,0,0">
                    <TextBlock Text="任务提醒" Foreground="#FFFFB300" FontSize="13" FontWeight="Bold"/>
                    <TextBlock x:Name="TimeText" Foreground="#FF9DA3B4" FontSize="11"/>
                </StackPanel>
            </StackPanel>
            <TextBlock x:Name="TaskText" Foreground="White" FontSize="15" FontWeight="Bold"
                       TextWrapping="Wrap" Margin="0,10,0,14"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="✓ 完成" Padding="12,5" Margin="0,0,8,0" Click="Done_Click"
                        Background="#FF43A047" Foreground="White" BorderThickness="0"/>
                <Button Content="5 分钟后再提醒" Padding="12,5" Margin="0,0,8,0" Click="Snooze_Click"
                        Background="#FF44475A" Foreground="White" BorderThickness="0"/>
                <Button Content="知道了" Padding="12,5" Click="Dismiss_Click"
                        Background="#FF44475A" Foreground="White" BorderThickness="0"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
